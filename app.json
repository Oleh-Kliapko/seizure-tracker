{
  "expo": {
    "name": "seizure-tracker",
    "slug": "seizure-tracker",
    "owner": "oleh_kliapko",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "seizuretracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "locales": {
      "uk": "./locales/ios/uk.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.olehkliapko.seizurestracker",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.899051190770-b9pgl03milrsig9vgf8611n3otel30bj"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow access to your camera to capture seizure videos and profile photos.",
        "NSPhotoLibraryUsageDescription": "Allow access to your photo library to select seizure videos and profile photos.",
        "NSPhotoLibraryAddUsageDescription": "Allow saving media to your photo library.",
        "NSMicrophoneUsageDescription": "Allow access to the microphone while recording seizure videos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-video",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "backgroundColor": "#4A90E2",
          "imageWidth": 220
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.899051190770-b9pgl03milrsig9vgf8611n3otel30bj"
        }
      ],
      "@react-native-firebase/app",
      [
        "@react-native-firebase/app-check",
        {
          "isTokenAutoRefreshEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b35306f5-7e71-4074-9aa3-6b6d195c45c5"
      }
    }
  }
}
